# Dukaan AI environment variables — copy this to .env aur values fill karo
# .env git mein commit NAHI hoti (gitignore mein hai). Ye file hoti hai.

# Required
GROQ_API_KEY=your_groq_key_here
DATABASE_URL=postgresql://user:password@host:port/dbname
SECRET_KEY=change-this-to-a-random-long-string

# Optional — WhatsApp Cloud API auto-send
# Agar ye set nahi hain toh app free "wa.me link" mode mein chalega
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v20.0
